# =============================================================================
#  Day 13 Observability Lab  —  Environment Configuration
#  Member B owns the LANGFUSE_* block below.
#  Copy this file to .env and fill in your real Langfuse credentials.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=dev
APP_NAME=day13-observability-lab
LOG_LEVEL=INFO
LOG_PATH=data/logs.jsonl
AUDIT_LOG_PATH=data/audit.jsonl

# ── Langfuse  (Member B)  ─────────────────────────────────────────────────────
#
#  HOW TO GET THESE VALUES:
#  1. Sign in at https://cloud.langfuse.com  (free tier, no credit card)
#  2. Create a new project, e.g. "day13-lab"
#  3. Go to Settings → API Keys → "Create new API key"
#  4. Copy the PUBLIC and SECRET keys below.
#
#  The SDK reads these three env-vars automatically on import — no extra
#  initialisation code is needed in tracing.py.
#
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Optional: self-hosted Langfuse ───────────────────────────────────────────
#  If your team runs a local Langfuse instance (docker-compose), change HOST:
#  LANGFUSE_HOST=http://localhost:3000

# ── Optional tuning ──────────────────────────────────────────────────────────
#  Flush traces every N seconds (default 15 in SDK; lower = faster UI updates)
#  LANGFUSE_FLUSH_INTERVAL=5
#
#  Disable tracing without removing decorators (useful in CI):
#  LANGFUSE_ENABLED=false
